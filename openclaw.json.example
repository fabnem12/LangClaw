{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "model": { "primary": "${MODEL_PRIMARY}" },
      "thinkingDefault": "medium",
      "timeoutSeconds": 1800,
      "heartbeat": { "every": "0m" }
    },
    "list": [
      {
        "id": "romanian",
        "default": false,
        "workspace": "~/.openclaw/workspace-romanian",
        "groupChat": {
          "mentionPatterns": ["@ana", "ana"]
        },
        "skills": ["language-learning", "conversation-partner"]
      },
      {
        "id": "german",
        "default": false,
        "workspace": "~/.openclaw/workspace-german",
        "groupChat": {
          "mentionPatterns": ["@lukas", "lukas"]
        },
        "skills": ["language-learning", "conversation-partner"]
      }
    ]
  },
  "bindings": [
    {
      "agentId": "romanian",
      "match": {
        "channel": "discord",
        "peer": { "kind": "channel", "id": "${DISCORD_ROMANIAN_CHANNEL_ID}" }
      }
    },
    {
      "agentId": "german",
      "match": {
        "channel": "discord",
        "peer": { "kind": "channel", "id": "${DISCORD_GERMAN_CHANNEL_ID}" }
      }
    }
  ],
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "guilds": {
        "${DISCORD_SERVER_ID}": {
          "channels": {
            "${DISCORD_ROMANIAN_CHANNEL_ID}": { "enabled": true },
            "${DISCORD_GERMAN_CHANNEL_ID}": { "enabled": true }
          }
        }
      }
    }
  },
  "session": {
    "scope": "per-sender",
    "resetTriggers": ["/new", "/reset"],
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 10080
    }
  },
  "cron": {
    "enabled": true
  },
  "skills": {
    "entries": {
      "language-learning": { "enabled": true },
      "conversation-partner": { "enabled": true }
    }
  }
}
