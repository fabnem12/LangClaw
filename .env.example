# LangClaw — Secrets Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Discord bot token (from Developer Portal → Bot → Reset Token)
DISCORD_BOT_TOKEN=your-bot-token-here

# Discord server (guild) ID (right-click server → Copy Server ID)
DISCORD_SERVER_ID=123456789012345678

# Discord channel IDs (right-click channel → Copy Channel ID)
DISCORD_ROMANIAN_CHANNEL_ID=123456789012345678
DISCORD_GERMAN_CHANNEL_ID=123456789012345678

# --- AI Model ---
# Choose your provider by setting MODEL_PRIMARY and the corresponding API key.
#
# Anthropic (Claude):
#   MODEL_PRIMARY=anthropic/claude-sonnet-4-6
#   ANTHROPIC_API_KEY=sk-ant-...
#
# OpenAI (GPT) — via ChatGPT subscription (recommended if you have one):
#   MODEL_PRIMARY=openai/gpt-5.5
#   (No API key needed — authenticate via: openclaw models auth login --provider openai)
#
# OpenAI (GPT) — via API key (separate billing from ChatGPT subscription):
#   MODEL_PRIMARY=openai/gpt-5.5
#   OPENAI_API_KEY=sk-...
#
# Other options:
#   openai/gpt-5.5-pro     (OpenAI more capable, higher cost)
#   openai/gpt-5.4         (OpenAI previous gen, cheaper)
#   anthropic/claude-opus-4-8  (Anthropic best quality, more expensive)
#   anthropic/claude-haiku-3-5 (Anthropic cheapest, fastest)

MODEL_PRIMARY=anthropic/claude-sonnet-4-6

# Anthropic API key (required if using Anthropic models)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (optional — only needed if using API key billing instead of ChatGPT subscription)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
